---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<BaseLayout title="About — British Schools Asia" description="What British Schools Asia is, who it's for, and how the index works.">
  <Header slot="header" />

  <section class="section">
    <div class="bsa-container">
      <div class="max-w-2xl">
        <p class="label mb-4">About</p>
        <h1 class="mb-8">About British Schools Asia</h1>

        <div class="space-y-6 font-body text-black/70 leading-relaxed">
          <p>
            British Schools Asia is an independent guide to British curriculum schools across the region. We publish rankings, fees, and editorial reviews to help families make informed decisions about international education.
          </p>

          <p>
            We cover schools in Singapore, Hong Kong, Thailand, Malaysia, and other Asian markets. Our team researches every school in the index — collecting fee data, reviewing reputations, and writing editorial assessments.
          </p>

          <p>
            The site is designed for expatriate families, relocating professionals, and anyone researching British education options in Asia. We aim to provide the kind of clear, independent information that school marketing materials do not.
          </p>

          <p>
            We are editorially independent. No school can pay to be ranked, promoted, or removed.
          </p>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
