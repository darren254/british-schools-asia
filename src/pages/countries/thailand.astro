---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SchoolCard from '../../components/SchoolCard.astro';
import CityCard from '../../components/CityCard.astro';
import schools from '../../data/schools.json';

const thSchools = schools
  .filter((s) => s.countrySlug === 'thailand')
  .sort((a, b) => a.asiaRank - b.asiaRank);
---
<BaseLayout title="British Schools in Thailand — Country Guide" description="All British curriculum schools in Thailand, ranked and reviewed. Fees, curricula, and city guides.">
  <Header slot="header" />

  <section class="section">
    <div class="bsa-container">
      <p class="label mb-4">Country</p>
      <h1 class="mb-6">British Schools in Thailand</h1>
      <div class="max-w-2xl">
        <p class="font-body text-black/70 mb-4">
          Thailand has become one of the most active markets for UK-branded international schools in Asia. Bangkok, the capital, hosts campuses of Shrewsbury, Harrow, Wellington College, and Brighton College — an unusual concentration of UK school names for any single city in the region.
        </p>
        <p class="font-body text-black/70">
          The British Schools Asia index currently includes four British curriculum schools in Thailand, all located in Bangkok. Fees are generally lower than in Singapore or Hong Kong, making Thailand attractive to families seeking British schooling at a more accessible price point.
        </p>
      </div>
    </div>
  </section>

  <hr class="divider bsa-container" />

  <!-- CITIES -->
  <section class="section">
    <div class="bsa-container">
      <p class="label mb-4">Cities</p>
      <h2 class="mb-10">Cities in Thailand</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-10">
        <CityCard city="Bangkok" slug="bangkok" schoolCount={thSchools.length} image="/images/bangkok-hero.jpg" />
      </div>
    </div>
  </section>

  <hr class="divider bsa-container" />

  <!-- RANKED SCHOOLS -->
  <section class="section">
    <div class="bsa-container">
      <p class="label mb-4">Ranked Schools</p>
      <h2 class="mb-10">All British schools in Thailand</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-10">
        {thSchools.map((school) => (
          <SchoolCard
            name={school.name}
            slug={school.slug}
            city={school.city}
            citySlug={school.citySlug}
            countrySlug={school.countrySlug}
            feeSummary={school.feeSummaryUSD}
            asiaRank={school.asiaRank}
            heroImage={school.heroImage}
          />
        ))}
      </div>
    </div>
  </section>

  <hr class="divider bsa-container" />

  <!-- JOURNAL LINKS -->
  <section class="section">
    <div class="bsa-container">
      <p class="label mb-4">From the Journal</p>
      <h2 class="mb-8">Related reading</h2>
      <div class="flex flex-col gap-6 max-w-xl">
        <a href="/journal/best-british-schools-bangkok" class="group no-underline block" style="text-decoration:none;">
          <p class="label text-black/40 mb-1">Cities</p>
          <p class="font-display text-xl group-hover:underline">Best British Schools in Bangkok</p>
        </a>
        <a href="/rankings" class="group no-underline block" style="text-decoration:none;">
          <p class="label text-black/40 mb-1">Rankings</p>
          <p class="font-display text-xl group-hover:underline">Asia's Top British Schools — Full Index</p>
        </a>
      </div>
    </div>
  </section>


  <hr class="divider bsa-container" />

  <!-- FAQ -->
  <section class="section">
    <div class="bsa-container">
      <div class="max-w-2xl">
        <p class="label mb-4">Frequently Asked Questions</p>
        <h2 class="mb-10">Common questions about British schools in Thailand</h2>
        <div class="pb-8 mb-8 border-b border-border">
            <h3 class="text-xl mb-3">How much do British schools cost in Thailand?</h3>
            <p class="font-body text-black/70">Tuition fees at British curriculum schools in Bangkok range from approximately THB 550,000 to THB 1.2 million per year (USD 16,000–35,000). Bangkok is generally more affordable than Singapore or Hong Kong for comparable UK-branded education.</p>
          </div>
        <div class="pb-8 mb-8 border-b border-border">
            <h3 class="text-xl mb-3">Which UK schools have campuses in Thailand?</h3>
            <p class="font-body text-black/70">Bangkok hosts campuses of Shrewsbury, Harrow, Wellington College, and Brighton College — all operating under licence or affiliation with their UK parent schools. This concentration of UK school brands is unusual in the region.</p>
          </div>
        <div class="pb-8 mb-8 border-b border-border">
            <h3 class="text-xl mb-3">Do any British schools in Thailand offer boarding?</h3>
            <p class="font-body text-black/70">Yes. Harrow International School Bangkok offers full boarding for students from Year 7. Other British schools in Bangkok are primarily day schools.</p>
          </div>
        <div class="pb-8">
            <h3 class="text-xl mb-3">What post-16 qualifications are available at British schools in Thailand?</h3>
            <p class="font-body text-black/70">British schools in Bangkok typically offer IGCSE followed by either A Levels or the IB Diploma. Shrewsbury and Harrow offer A Levels, while others may route through the IB.</p>
          </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
