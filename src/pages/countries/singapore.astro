---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SchoolCard from '../../components/SchoolCard.astro';
import CityCard from '../../components/CityCard.astro';
import schools from '../../data/schools.json';

const sgSchools = schools
  .filter((s) => s.countrySlug === 'singapore')
  .sort((a, b) => a.asiaRank - b.asiaRank);
---
<BaseLayout title="British Schools in Singapore — Country Guide" description="All British curriculum schools in Singapore, ranked and reviewed. Fees, curricula, and city guides.">
  <Header slot="header" />

  <section class="section">
    <div class="bsa-container">
      <p class="label mb-4">Country</p>
      <h1 class="mb-6">British Schools in Singapore</h1>
      <div class="max-w-2xl">
        <p class="font-body text-black/70 mb-4">
          Singapore is a city-state with a mature international school sector. As both a country and a city, it offers a concentrated market where all British curriculum schools are easily accessible from any part of the island.
        </p>
        <p class="font-body text-black/70">
          The British Schools Asia index currently includes four British curriculum schools in Singapore, all located within the city. Fees are among the highest in the region, but the quality of facilities, teaching, and regulatory oversight is consistently strong.
        </p>
      </div>
    </div>
  </section>

  <hr class="divider bsa-container" />

  <!-- CITIES IN THIS COUNTRY -->
  <section class="section">
    <div class="bsa-container">
      <p class="label mb-4">Cities</p>
      <h2 class="mb-10">Cities in Singapore</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-10">
        <CityCard city="Singapore" slug="singapore" schoolCount={sgSchools.length} image="/images/singapore-hero.jpg" />
      </div>
    </div>
  </section>

  <hr class="divider bsa-container" />

  <!-- RANKED SCHOOLS -->
  <section class="section">
    <div class="bsa-container">
      <p class="label mb-4">Ranked Schools</p>
      <h2 class="mb-10">All British schools in Singapore</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-10">
        {sgSchools.map((school) => (
          <SchoolCard
            name={school.name}
            slug={school.slug}
            city={school.city}
            citySlug={school.citySlug}
            countrySlug={school.countrySlug}
            feeSummary={school.feeSummaryUSD}
            asiaRank={school.asiaRank}
            heroImage={school.heroImage}
          />
        ))}
      </div>
    </div>
  </section>

  <hr class="divider bsa-container" />

  <!-- JOURNAL LINKS -->
  <section class="section">
    <div class="bsa-container">
      <p class="label mb-4">From the Journal</p>
      <h2 class="mb-8">Related reading</h2>
      <div class="flex flex-col gap-6 max-w-xl">
        <a href="/journal/best-british-schools-singapore" class="group no-underline block" style="text-decoration:none;">
          <p class="label text-black/40 mb-1">Cities</p>
          <p class="font-display text-xl group-hover:underline">Best British Schools in Singapore</p>
        </a>
        <a href="/rankings" class="group no-underline block" style="text-decoration:none;">
          <p class="label text-black/40 mb-1">Rankings</p>
          <p class="font-display text-xl group-hover:underline">Asia's Top British Schools — Full Index</p>
        </a>
      </div>
    </div>
  </section>


  <hr class="divider bsa-container" />

  <!-- FAQ -->
  <section class="section">
    <div class="bsa-container">
      <div class="max-w-2xl">
        <p class="label mb-4">Frequently Asked Questions</p>
        <h2 class="mb-10">Common questions about British schools in Singapore</h2>
        <div class="pb-8 mb-8 border-b border-border">
            <h3 class="text-xl mb-3">How much do British schools cost in Singapore?</h3>
            <p class="font-body text-black/70">Tuition fees at British curriculum schools in Singapore typically range from SGD 28,000 to SGD 50,000 per year, depending on the year group. Most schools also charge a non-refundable building or capital levy of SGD 3,000–6,000 annually.</p>
          </div>
        <div class="pb-8 mb-8 border-b border-border">
            <h3 class="text-xl mb-3">Which British schools in Singapore offer A Levels?</h3>
            <p class="font-body text-black/70">Tanglin Trust School is the only British school in Singapore that offers A Levels alongside the IB Diploma. Most other British schools in Singapore transition to the IB Diploma after IGCSEs.</p>
          </div>
        <div class="pb-8 mb-8 border-b border-border">
            <h3 class="text-xl mb-3">Are there waitlists at British schools in Singapore?</h3>
            <p class="font-body text-black/70">Yes. The most established schools, particularly Tanglin Trust, report waitlists in popular year groups. Parents are advised to apply early, especially for Infant and Junior School entry.</p>
          </div>
        <div class="pb-8">
            <h3 class="text-xl mb-3">How many British curriculum schools are in Singapore?</h3>
            <p class="font-body text-black/70">The British Schools Asia index currently includes four British curriculum schools in Singapore: Tanglin Trust School, Brighton College, Dulwich College, and Nexus International School.</p>
          </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
