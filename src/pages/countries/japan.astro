---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SchoolCard from '../../components/SchoolCard.astro';
import CityCard from '../../components/CityCard.astro';
import schools from '../../data/schools.json';

const jpSchools = schools
  .filter((s) => s.countrySlug === 'japan')
  .sort((a, b) => a.asiaRank - b.asiaRank);
---
<BaseLayout title="British Schools in Japan — Country Guide" description="British curriculum schools in Japan, ranked and reviewed. Fees, curricula, and city guides.">
  <Header slot="header" />

  <section class="section">
    <div class="bsa-container">
      <p class="label mb-4">Country</p>
      <h1 class="mb-6">British Schools in Japan</h1>
      <div class="max-w-2xl">
        <p class="font-body text-black/70 mb-4">
          Japan has a limited market for British curriculum education. The British School in Tokyo is the country's primary option for families seeking the English National Curriculum. Japan's international school sector is small relative to the size of its economy, reflecting both regulatory factors and the strength of the domestic education system.
        </p>
        <p class="font-body text-black/70">
          The British Schools Asia index includes one school in Japan, located in Tokyo. Tuition is mid-range by Asian standards, but Tokyo's high cost of living means the total expense of an international education is substantial.
        </p>
      </div>
    </div>
  </section>

  <hr class="divider bsa-container" />

  <!-- CITIES -->
  <section class="section">
    <div class="bsa-container">
      <p class="label mb-4">Cities</p>
      <h2 class="mb-10">Cities in Japan</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-10">
        <CityCard city="Tokyo" slug="tokyo" schoolCount={jpSchools.length} image="/images/tokyo-hero.jpg" />
      </div>
    </div>
  </section>

  <hr class="divider bsa-container" />

  <!-- RANKED SCHOOLS -->
  <section class="section">
    <div class="bsa-container">
      <p class="label mb-4">Ranked Schools</p>
      <h2 class="mb-10">All British schools in Japan</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-10">
        {jpSchools.map((school) => (
          <SchoolCard
            name={school.name}
            slug={school.slug}
            city={school.city}
            citySlug={school.citySlug}
            countrySlug={school.countrySlug}
            feeSummary={school.feeSummaryUSD}
            asiaRank={school.asiaRank}
            heroImage={school.heroImage}
          />
        ))}
      </div>
    </div>
  </section>

  <hr class="divider bsa-container" />

  <!-- JOURNAL LINKS -->
  <section class="section">
    <div class="bsa-container">
      <p class="label mb-4">From the Journal</p>
      <h2 class="mb-8">Related reading</h2>
      <div class="flex flex-col gap-6 max-w-xl">
        <a href="/rankings" class="group no-underline block" style="text-decoration:none;">
          <p class="label text-black/40 mb-1">Rankings</p>
          <p class="font-display text-xl group-hover:underline">Asia's Top British Schools — Full Index</p>
        </a>
      </div>
    </div>
  </section>


  <hr class="divider bsa-container" />

  <!-- FAQ -->
  <section class="section">
    <div class="bsa-container">
      <div class="max-w-2xl">
        <p class="label mb-4">Frequently Asked Questions</p>
        <h2 class="mb-10">Common questions about British schools in Japan</h2>
        <div class="pb-8 mb-8 border-b border-border">
            <h3 class="text-xl mb-3">How much does The British School in Tokyo cost?</h3>
            <p class="font-body text-black/70">Annual tuition at The British School in Tokyo ranges from approximately JPY 2.4 million to JPY 2.8 million (USD 16,000–19,000), depending on the year group. Additional fees apply for registration, facilities, and school trips.</p>
          </div>
        <div class="pb-8 mb-8 border-b border-border">
            <h3 class="text-xl mb-3">Is The British School in Tokyo the only British school in Japan?</h3>
            <p class="font-body text-black/70">The British School in Tokyo is the primary British curriculum school in Japan indexed by British Schools Asia. It is the longest-established British school in the country, operating since 1989.</p>
          </div>
        <div class="pb-8">
            <h3 class="text-xl mb-3">What curriculum does The British School in Tokyo follow?</h3>
            <p class="font-body text-black/70">The school follows the English National Curriculum from Early Years through IGCSEs. For Sixth Form, it offers the IB Diploma Programme rather than A Levels.</p>
          </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
