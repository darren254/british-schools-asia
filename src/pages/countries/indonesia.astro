---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SchoolCard from '../../components/SchoolCard.astro';
import CityCard from '../../components/CityCard.astro';
import schools from '../../data/schools.json';

const idSchools = schools
  .filter((s) => s.countrySlug === 'indonesia')
  .sort((a, b) => a.asiaRank - b.asiaRank);
---
<BaseLayout title="British Schools in Indonesia — Country Guide" description="British curriculum schools in Indonesia, ranked and reviewed. Fees, curricula, and city guides.">
  <Header slot="header" />

  <section class="section">
    <div class="bsa-container">
      <p class="label mb-4">Country</p>
      <h1 class="mb-6">British Schools in Indonesia</h1>
      <div class="max-w-2xl">
        <p class="font-body text-black/70 mb-4">
          Indonesia is Southeast Asia's largest economy, and Jakarta — its capital — hosts a well-established British school. The British School Jakarta has been operating since 1973, making it one of the longest-running British curriculum schools in the region. Indonesia's international school sector operates under a cooperative education framework.
        </p>
        <p class="font-body text-black/70">
          The British Schools Asia index includes one school in Indonesia, based in Jakarta. Fee levels are competitive compared to other Asian markets, with annual tuition at approximately IDR 328 million (roughly USD 20,000).
        </p>
      </div>
    </div>
  </section>

  <hr class="divider bsa-container" />

  <!-- CITIES -->
  <section class="section">
    <div class="bsa-container">
      <p class="label mb-4">Cities</p>
      <h2 class="mb-10">Cities in Indonesia</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-10">
        <CityCard city="Jakarta" slug="jakarta" schoolCount={idSchools.length} image="/images/jakarta-hero.jpg" />
      </div>
    </div>
  </section>

  <hr class="divider bsa-container" />

  <!-- RANKED SCHOOLS -->
  <section class="section">
    <div class="bsa-container">
      <p class="label mb-4">Ranked Schools</p>
      <h2 class="mb-10">All British schools in Indonesia</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-10">
        {idSchools.map((school) => (
          <SchoolCard
            name={school.name}
            slug={school.slug}
            city={school.city}
            citySlug={school.citySlug}
            countrySlug={school.countrySlug}
            feeSummary={school.feeSummaryUSD}
            asiaRank={school.asiaRank}
            heroImage={school.heroImage}
          />
        ))}
      </div>
    </div>
  </section>

  <hr class="divider bsa-container" />

  <!-- JOURNAL LINKS -->
  <section class="section">
    <div class="bsa-container">
      <p class="label mb-4">From the Journal</p>
      <h2 class="mb-8">Related reading</h2>
      <div class="flex flex-col gap-6 max-w-xl">
        <a href="/rankings" class="group no-underline block" style="text-decoration:none;">
          <p class="label text-black/40 mb-1">Rankings</p>
          <p class="font-display text-xl group-hover:underline">Asia's Top British Schools — Full Index</p>
        </a>
      </div>
    </div>
  </section>


  <hr class="divider bsa-container" />

  <!-- FAQ -->
  <section class="section">
    <div class="bsa-container">
      <div class="max-w-2xl">
        <p class="label mb-4">Frequently Asked Questions</p>
        <h2 class="mb-10">Common questions about British schools in Indonesia</h2>
        <div class="pb-8 mb-8 border-b border-border">
            <h3 class="text-xl mb-3">How much does the British School Jakarta cost?</h3>
            <p class="font-body text-black/70">Annual tuition at British School Jakarta ranges from approximately IDR 210 million to IDR 440 million (USD 13,000–27,000), depending on the year group. Additional fees apply for registration and capital development.</p>
          </div>
        <div class="pb-8 mb-8 border-b border-border">
            <h3 class="text-xl mb-3">Is British School Jakarta the only British school in Indonesia?</h3>
            <p class="font-body text-black/70">British School Jakarta is the primary British curriculum school in Indonesia indexed by British Schools Asia. While other international schools in Jakarta may offer some British curriculum elements, BSJ is the most established fully British school in the country.</p>
          </div>
        <div class="pb-8">
            <h3 class="text-xl mb-3">What post-16 qualifications does British School Jakarta offer?</h3>
            <p class="font-body text-black/70">British School Jakarta offers the IB Diploma Programme in Sixth Form, following the English National Curriculum and IGCSEs through Year 11. The school does not offer A Levels.</p>
          </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
