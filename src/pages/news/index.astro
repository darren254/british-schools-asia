---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Load all news article JSON files at build time
const articleFiles = import.meta.glob('../../data/news/*.json', { eager: true });
const articles = Object.values(articleFiles)
  .map((m: any) => m.default || m)
  .filter((a: any) => a && a.slug)
  .sort((a: any, b: any) => (a.date < b.date ? 1 : -1));

const formatDate = (iso: string) => {
  const d = new Date(iso);
  return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });
};

const featured = articles[0];
const rest = articles.slice(1);
---
<BaseLayout
  title="News"
  description="Daily news on British curriculum and international schools across Asia — fees, inspections, regulation, and school-specific developments."
>
  <Header slot="header" />

  <!-- Page header -->
  <section class="bsa-container pt-12 md:pt-16 pb-8 md:pb-10">
    <p class="label text-black/50 mb-4">News</p>
    <h1 class="font-display text-4xl md:text-5xl leading-tight max-w-3xl">
      The latest on Asia's British and international schools
    </h1>
    <p class="font-body text-base text-black/60 mt-4 max-w-2xl">
      A daily edit of the most consequential stories — fees, regulation, inspections, and school-specific developments — across our covered cities.
    </p>
  </section>

  <hr class="divider bsa-container" />

  {featured && (
    <section class="bsa-container py-10 md:py-14">
      <a href={`/news/${featured.slug}`} class="grid md:grid-cols-2 gap-8 md:gap-12 group no-underline" style="text-decoration:none;">
        <div class="aspect-[4/3] overflow-hidden bg-black/5">
          <img
            src={featured.heroImage}
            alt={featured.heroAlt}
            class="w-full h-full object-cover group-hover:opacity-90 transition-opacity"
            loading="eager"
          />
        </div>
        <div class="flex flex-col justify-center">
          <p class="label text-black/50 mb-4">{featured.kicker}</p>
          <h2 class="font-display text-3xl md:text-4xl leading-tight mb-4 text-black">{featured.headline}</h2>
          <p class="font-body text-base text-black/70 leading-relaxed mb-4">{featured.dek}</p>
          <p class="font-body text-xs text-black/50">{formatDate(featured.date)}</p>
        </div>
      </a>
    </section>
  )}

  {rest.length > 0 && (
    <>
      <hr class="divider-subtle bsa-container" />
      <section class="bsa-container py-10 md:py-14">
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-10 md:gap-12">
          {rest.map((article: any) => (
            <a href={`/news/${article.slug}`} class="flex flex-col group no-underline" style="text-decoration:none;">
              <div class="aspect-[4/3] overflow-hidden bg-black/5 mb-4">
                <img
                  src={article.heroImage}
                  alt={article.heroAlt}
                  class="w-full h-full object-cover group-hover:opacity-90 transition-opacity"
                  loading="lazy"
                />
              </div>
              <p class="label text-black/50 mb-2">{article.kicker}</p>
              <h3 class="font-display text-2xl leading-tight mb-2 text-black">{article.headline}</h3>
              <p class="font-body text-sm text-black/60 leading-relaxed mb-3">{article.dek}</p>
              <p class="font-body text-xs text-black/50 mt-auto">{formatDate(article.date)}</p>
            </a>
          ))}
        </div>
      </section>
    </>
  )}

  {articles.length === 0 && (
    <section class="bsa-container py-16">
      <p class="font-body text-black/60">No news articles yet — check back soon.</p>
    </section>
  )}

  <Footer slot="footer" />
</BaseLayout>
