---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="British Schools Asia" description="A curated index of Asia's top British schools. Rankings, fees, and independent editorial reviews.">

  <!-- Placeholder: Utility ribbon component (Phase 2) -->
  <!-- Placeholder: Header component (Phase 2) -->

  <div class="section">
    <div class="container">
      <h1>Find the top British schools in Asia</h1>
      <p class="mt-6" style="max-width: var(--width-narrow); font-size: var(--text-lg);">
        A curated, editorially independent index of British curriculum schools across Asia's major cities. Ranked by fees. Adjusted by reputation.
      </p>

      <hr class="divider mt-12 mb-12" />

      <!-- Phase 1 type specimen -->
      <div class="mt-16">
        <p class="label mb-4">Design System Check</p>
        <h2 class="mb-4">Typography &amp; Spacing</h2>
        <p>Body text at 15px Inter. Headings in Cormorant Garamond. This paragraph verifies the base type stack renders correctly before Phase 2 component work begins.</p>

        <div class="mt-8 flex gap-4 flex-wrap">
          <a href="#" class="btn-primary">Primary Button</a>
          <a href="#" class="btn-ghost-dark">Ghost Button</a>
        </div>
      </div>
    </div>
  </div>

</BaseLayout>
