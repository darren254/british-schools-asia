---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SchoolCard from '../../components/SchoolCard.astro';
import schools from '../../data/schools.json';

const citySchools = schools
  .filter((s) => s.citySlug === 'tokyo')
  .sort((a, b) => a.cityRank - b.cityRank);

const faqs = [
  {
    q: 'How much does The British School in Tokyo cost?',
    a: 'Annual tuition at The British School in Tokyo is approximately JPY 2.82 million (roughly USD 18,900). Japan has a very high cost of living, and housing costs in central Tokyo can significantly add to the overall expense of an international education.'
  },
  {
    q: 'Is The British School in Tokyo the only British curriculum school in the city?',
    a: 'The British School in Tokyo (BST) is the primary British curriculum school in Tokyo and the only one currently included in the British Schools Asia index. There are other international schools in Tokyo, but BST is the main option for families specifically seeking the English National Curriculum.'
  },
  {
    q: 'What curriculum does BST follow?',
    a: 'BST follows the English National Curriculum from Early Years through to IGCSE. The school offers both A Levels and the IB Diploma in Sixth Form, giving students a choice of post-16 pathway.'
  }
];
---
<BaseLayout title="British Schools in Tokyo" description="Guide to British curriculum schools in Tokyo, with fees, curricula, and independent reviews.">
  <Header slot="header" />

  <!-- HERO -->
  <section class="relative w-full h-[50vh] min-h-[350px] overflow-hidden">
    <img
      src="/images/tokyo-hero.jpg"
      alt="Tokyo cityscape"
      class="absolute inset-0 w-full h-full object-cover"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 p-6 md:p-12">
      <div class="bsa-container">
        <p class="label text-white/70 mb-3">City Guide</p>
        <h1 class="text-white text-4xl md:text-5xl">British Schools in Tokyo</h1>
      </div>
    </div>
  </section>

  <!-- INTRO -->
  <section class="section">
    <div class="bsa-container">
      <div class="max-w-2xl">
        <p class="font-body text-black/70 mb-4">
          Tokyo has a limited market for British curriculum education. The British School in Tokyo (BST) is the city's primary option for families seeking the English National Curriculum, IGCSE, and A Level or IB Diploma pathways. Unlike Hong Kong, Singapore, or Bangkok — where multiple British schools compete for enrolments — Tokyo's British school market is effectively a single-school market.
        </p>
        <p class="font-body text-black/70 mb-4">
          Annual tuition at BST is approximately JPY 2.82 million (roughly USD 18,900 per year). While the tuition itself is mid-range by regional standards, Tokyo's very high cost of living — particularly housing — means the total expense of an international education in the city is substantial. Families should factor in accommodation, transport, and daily costs when budgeting.
        </p>
        <p class="font-body text-black/70">
          BST has a long history in the city and draws students from Tokyo's international community, including British, European, and other expat families. The school offers both A Levels and the IB Diploma in Sixth Form, which is notable given the limited market size.
        </p>
      </div>
    </div>
  </section>

  <hr class="divider bsa-container" />

  <!-- RANKED SCHOOLS -->
  <section class="section">
    <div class="bsa-container">
      <p class="label mb-4">Ranked Schools</p>
      <h2 class="mb-10">Tokyo's British schools</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-x-6 gap-y-10">
        {citySchools.map((school) => (
          <SchoolCard
            name={school.name}
            slug={school.slug}
            city={school.city}
            citySlug={school.citySlug}
            countrySlug={school.countrySlug}
            feeSummary={school.feeSummaryUSD}
            asiaRank={school.asiaRank}
            heroImage={school.heroImage}
          />
        ))}
      </div>
    </div>
  </section>

  <hr class="divider bsa-container" />

  <!-- MARKET CONTEXT -->
  <section class="section">
    <div class="bsa-container">
      <div class="max-w-2xl">
        <p class="label mb-4">Market Context</p>
        <h2 class="mb-6">Understanding Tokyo's British school market</h2>
        <p class="font-body text-black/70 mb-4">
          Japan's international school sector is comparatively small relative to the country's economy. Tokyo hosts a number of international schools — American, international baccalaureate, and others — but the British curriculum market is narrow. BST serves as the primary destination for British families and those seeking the English National Curriculum specifically.
        </p>
        <p class="font-body text-black/70 mb-4">
          Regulatory requirements for international schools in Japan are less prescriptive than in some other Asian markets, but schools must meet local safety and operational standards. BST operates as an independent school within this framework.
        </p>
        <p class="font-body text-black/70">
          The limited supply of British curriculum places in Tokyo means that BST does not face the same competitive pressure as schools in multi-school markets like Singapore or Bangkok. Families with a strong preference for British education in Tokyo will find BST is effectively the sole option.
        </p>
      </div>
    </div>
  </section>

  <hr class="divider bsa-container" />

  <!-- FAQ -->
  <section class="section">
    <div class="bsa-container">
      <div class="max-w-2xl">
        <p class="label mb-4">Frequently Asked Questions</p>
        <h2 class="mb-10">Common questions about British schools in Tokyo</h2>
        {faqs.map((faq, i) => (
          <div class:list={['pb-8', { 'mb-8 border-b border-border': i < faqs.length - 1 }]}>
            <h3 class="text-xl mb-3">{faq.q}</h3>
            <p class="font-body text-black/70">{faq.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <hr class="divider bsa-container" />

  <!-- RELATED JOURNAL ARTICLES -->
  <section class="section">
    <div class="bsa-container">
      <p class="label mb-4">From the Journal</p>
      <h2 class="mb-8">Related reading</h2>
      <div class="flex flex-col gap-6 max-w-xl">
        <a href="/rankings" class="group no-underline block" style="text-decoration:none;">
          <p class="label text-black/40 mb-1">Rankings</p>
          <p class="font-display text-xl group-hover:underline">Asia's Top British Schools — Full Index</p>
        </a>
      </div>
    </div>
  </section>
  <hr class="divider bsa-container" />

  <!-- INTERNAL LINKS -->
  <section class="section">
    <div class="bsa-container">
      <p class="label mb-4">Explore</p>
      <h2 class="mb-6">Continue browsing</h2>
      <div class="flex flex-col gap-3 max-w-xl">
        <a href="/countries/japan" class="font-body text-sm hover:underline" style="text-decoration:none;">British Schools in Japan — Country Guide</a>
        <a href="/cities" class="font-body text-sm hover:underline" style="text-decoration:none;">All Cities</a>
        <a href="/countries" class="font-body text-sm hover:underline" style="text-decoration:none;">All Countries</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>
